---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import FadeIn from "../components/FadeIn.astro";
import AnimatedTimeline from "../components/AnimatedTimeline.astro";
import LocalBusinessSchema from "../components/seo/LocalBusinessSchema.astro";

const processSteps = [
  {
    title: "We praten",
    description: "Een kort gesprek over je bedrijf en wat je nodig hebt. Geen verplichtingen.",
  },
  {
    title: "Ik maak een voorstel",
    description: "Je krijgt een duidelijk voorstel. Wat ik ga maken, hoe lang het duurt, wat het kost.",
  },
  {
    title: "Ik bouw",
    description: "Ik ga aan de slag. Tussendoor laat ik zien hoe het ervoor staat.",
  },
  {
    title: "Je bent online",
    description: "Je website gaat live. Klaar om gevonden te worden.",
  },
];
---

<Layout
  title="Professionele Websites voor Ondernemers | KNAP GEMAAKT."
  description="Ik bouw websites en webshops voor lokale ondernemers. Persoonlijk contact, eerlijke prijzen. KNAP GEMAAKT. uit Buren."
>
  <LocalBusinessSchema />
  <main>
    <!-- HERO -->
    <section class="min-h-[85vh] flex flex-col justify-center relative overflow-hidden px-6 md:px-12 lg:px-16 py-24">
      <!-- Gradient orbs -->
      <div class="hero-orb hidden md:block w-[500px] h-[500px] bg-accent/[0.06] top-1/4 -right-1/4"></div>
      <div class="hero-orb hidden md:block w-[400px] h-[400px] bg-accent/[0.04] bottom-1/4 -left-1/4" style="animation-delay: -10s"></div>

      <div class="max-w-5xl mx-auto w-full relative z-10 grid md:grid-cols-5 gap-12 md:gap-16 items-center">
        <div class="md:col-span-3">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-snug mb-6 md:mb-8">
            Jouw bedrijf verdient een website die <span class="text-accent">werkt</span>.
          </h1>

          <p class="text-lg md:text-xl text-ink-secondary max-w-2xl mb-10 md:mb-12 leading-relaxed">
            Ik bouw websites en webshops voor ondernemers die online goed voor de dag willen komen. Gewoon goed werk, zonder gedoe.
          </p>

          <a
            href="/contact/"
            class="bg-ink text-canvas px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
          >
            Neem contact op
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <div class="hidden md:block md:col-span-2">
          <div class="relative">
            <div class="absolute -inset-4 bg-accent/10 rounded-3xl blur-2xl"></div>
            <img
              src="/assets/yannick.webp"
              alt="Yannick Veldhuisen, oprichter van KNAP GEMAAKT."
              class="relative rounded-2xl w-full aspect-[3/4] object-cover object-top"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- PROBLEM RECOGNITION -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60 mb-4 block">Dit hoor ik vaak</span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 md:mb-16">
            Klinkt dit bekend?
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-2 gap-6">
          <FadeIn delay={100}>
            <div class="glass-card p-6 md:p-8 cursor-default">
              <div class="w-2 h-2 rounded-full bg-accent mb-4"></div>
              <h3 class="text-lg font-bold mb-2">"Mijn website is een beetje... meh"</h3>
              <p class="text-ink-secondary leading-relaxed">Je doet goed werk, maar je website laat dat niet zien. Dat is zonde.</p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="glass-card p-6 md:p-8 cursor-default">
              <div class="w-2 h-2 rounded-full bg-accent mb-4"></div>
              <h3 class="text-lg font-bold mb-2">"Mensen vinden me niet online"</h3>
              <p class="text-ink-secondary leading-relaxed">Je concurrent staat bovenaan in Google. Jij niet. Terwijl je minstens zo goed bent.</p>
            </div>
          </FadeIn>

          <FadeIn delay={300}>
            <div class="glass-card p-6 md:p-8 cursor-default">
              <div class="w-2 h-2 rounded-full bg-accent mb-4"></div>
              <h3 class="text-lg font-bold mb-2">"Ik betaal veel maar het levert niks op"</h3>
              <p class="text-ink-secondary leading-relaxed">Maandelijkse kosten voor iets waar je eigenlijk niet blij mee bent. Herkenbaar.</p>
            </div>
          </FadeIn>

          <FadeIn delay={400}>
            <div class="glass-card p-6 md:p-8 cursor-default">
              <div class="w-2 h-2 rounded-full bg-accent mb-4"></div>
              <h3 class="text-lg font-bold mb-2">"Ik heb er eigenlijk geen tijd voor"</h3>
              <p class="text-ink-secondary leading-relaxed">Je bent druk met je vak. Zelf een website bouwen kost avonden die je niet hebt.</p>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- CAPABILITY GRID -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60 mb-4 block">Wat ik doe</span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 md:mb-16">
            Hier kan ik je mee helpen
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-2 gap-6">
          <!-- Large card: Websites -->
          <FadeIn delay={100} class="md:row-span-2">
            <div class="glass-card p-8 md:p-10 h-full flex flex-col cursor-default">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
              </div>
              <h3 class="text-xl font-bold mb-3">Websites</h3>
              <p class="text-ink-secondary leading-relaxed mb-6">
                Een website die bij je past en waar je trots op bent. Ik regel alles: ontwerp, teksten, hosting. Jij hoeft alleen feedback te geven.
              </p>
              <div class="mt-auto pt-4 border-t border-warm">
                <span class="text-sm text-ink-secondary">Design, tekst, hosting en SEO inbegrepen</span>
              </div>
            </div>
          </FadeIn>

          <!-- Webshops -->
          <FadeIn delay={200}>
            <div class="glass-card p-8 cursor-default">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              </div>
              <h3 class="text-xl font-bold mb-2">Webshops</h3>
              <p class="text-ink-secondary leading-relaxed">
                Een Shopify webshop die er goed uitziet en die je zelf makkelijk kunt beheren.
              </p>
            </div>
          </FadeIn>

          <!-- Online zichtbaarheid -->
          <FadeIn delay={300}>
            <div class="glass-card p-8 cursor-default">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              </div>
              <h3 class="text-xl font-bold mb-2">Gevonden worden</h3>
              <p class="text-ink-secondary leading-relaxed">
                Elke website die ik bouw is geoptimaliseerd voor Google. Zodat klanten jou vinden, niet je concurrent.
              </p>
            </div>
          </FadeIn>
        </div>

        <FadeIn delay={400}>
          <div class="mt-10 text-center">
            <a
              href="/wat-ik-doe/"
              class="text-ink font-bold inline-flex items-center gap-2 hover:text-accent transition-colors group"
            >
              Bekijk alles wat ik doe
              <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60 mb-4 block">Zo werkt het</span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 md:mb-16">
            Van eerste gesprek tot live website
          </h2>
        </FadeIn>

        <FadeIn delay={200}>
          <AnimatedTimeline steps={processSteps} />
        </FadeIn>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
          <FadeIn>
            <div class="relative">
              <img
                src="/assets/yannick.webp"
                alt="Yannick Veldhuisen, oprichter van KNAP GEMAAKT."
                class="rounded-2xl w-full max-w-md"
                loading="lazy"
              />
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div>
              <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60 mb-4 block">Wie ik ben</span>
              <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
                Hoi, ik ben Yannick
              </h2>
              <p class="text-ink-secondary leading-relaxed mb-4">
                Ik bouw websites vanuit Buren voor ondernemers in de regio en daarbuiten. Geen team, geen kantoor. Gewoon persoonlijk contact en eerlijk advies.
              </p>
              <p class="text-ink-secondary leading-relaxed mb-6">
                Als er iets is, bel je me gewoon. Zo simpel is het.
              </p>

              <div class="flex flex-wrap gap-4 mb-6">
                <span class="text-xs font-medium bg-canvas-alt px-3 py-1.5 rounded-full text-ink-secondary">KVK: 73652377</span>
                <span class="text-xs font-medium bg-canvas-alt px-3 py-1.5 rounded-full text-ink-secondary">Buren, Rivierenland</span>
              </div>

              <a
                href="/over-mij/"
                class="text-ink font-bold inline-flex items-center gap-2 hover:text-accent transition-colors group"
              >
                Meer over mij
                <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
