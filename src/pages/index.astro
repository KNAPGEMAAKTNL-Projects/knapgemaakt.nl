---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import FadeIn from "../components/FadeIn.astro";
import LocalBusinessSchema from "../components/seo/LocalBusinessSchema.astro";
import { TypingRotator } from "../components/TypingRotator";
import { DraggableScroll } from "../components/DraggableScroll";
import { getAllProjects } from "../data/projects";
import { stage0Offer, spotsLabel, bedrijvenLabel } from "../config/stage-0-offer";

const projects = getAllProjects();
---

<Layout
  title="Websites voor Ondernemers Buren | KNAP GEMAAKT."
  description="Maatwerk websites voor ondernemers. Goed gevonden in Google, vanaf €47 per maand, inclusief hosting, onderhoud en lead-opvolging."
>
  <LocalBusinessSchema />
  <main>
    <!-- HERO (sticky: next section slides up over it on scroll) -->
    <section class="hero-sticky min-h-screen flex flex-col justify-center relative px-6 md:px-12 lg:px-16 py-24 sticky top-0 z-0 overflow-clip">
      <div class="max-w-5xl mx-auto w-full relative z-10">
        <h1 class="mb-6 md:mb-8">
          <span class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-snug block">
            Een website die
          </span>
          <span class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-snug block relative mt-2">
            {/* Server-rendered placeholder for SEO (hidden immediately, typing animates in) */}
            <span id="typing-placeholder" class="text-accent invisible">gevonden wordt.</span>
            <span class="absolute left-0 top-0 text-accent">
              <TypingRotator
                client:load
                prefix=""
                words={["gevonden wordt.", "vertrouwen wekt.", "klanten oplevert.", "met je meegroeit."]}
                typingSpeed={80}
                deletingSpeed={40}
                pauseDuration={2500}
              />
            </span>
          </span>
        </h1>

        <p class="text-lg md:text-xl text-ink/70 max-w-2xl mb-10 md:mb-12 leading-relaxed">
          Voor ondernemers die hun vak serieus nemen. Maatwerk, met Google-vindbaarheid en lead-opvolging in één overzichtelijk pakket.
        </p>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <a
            href="/aanvragen/"
            class="bg-ink text-canvas px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center"
          >
            Plan een kennismaking
          </a>
          <a
            href="/werk/"
            class="text-ink font-bold tracking-tight hover:text-accent transition-colors duration-300 inline-flex items-center gap-2 group px-4 py-4"
          >
            Bekijk werk
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        {stage0Offer.enabled && (
          <div class="mt-8 flex items-start gap-3 max-w-xl">
            <span class="w-2 h-2 rounded-full bg-accent mt-2 shrink-0"></span>
            <p class="text-sm text-ink/70 leading-relaxed">
              <strong class="text-ink">Nu in {stage0Offer.month}: {spotsLabel()} gratis.</strong>
              {' '}Ik maak voor {bedrijvenLabel()} een volledige website, in ruil voor een case study na 90 dagen.
              {' '}<a href={stage0Offer.detailsUrl} class="underline hover:text-accent transition-colors">Zo werkt het &rarr;</a>
            </p>
          </div>
        )}
      </div>
    </section>

    <!-- SERVICE CARDS (slides up over hero) -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-canvas-alt relative z-10 rounded-t-3xl shadow-[0_-20px_60px_-15px_rgba(0,0,0,0.08)]">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">De aanpak</span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
            Een website die voor je blijft werken
          </h2>
          <p class="text-ink/70 text-lg leading-relaxed max-w-2xl mb-12 md:mb-16">
            Een website is pas iets waard als ie ook werkt. Gevonden worden in Google, aanvragen direct naar je telefoon, reviews die binnenkomen en onderhoud waar je niet aan hoeft te denken. Dat regelen we in één pakket, onder één maandbedrag.
          </p>
        </FadeIn>

        <div class="grid md:grid-cols-[7fr_5fr] gap-6">
          <FadeIn delay={100}>
            <a href="/webdesign/" class="glass-card p-8 md:p-10 flex flex-col cursor-pointer group block h-full">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
              </div>
              <span class="text-xs font-mono uppercase tracking-widest text-ink/40 mb-2">Het pakket</span>
              <h3 class="text-2xl font-bold mb-3">Wat je krijgt</h3>
              <p class="text-ink/70 leading-relaxed mb-4">
                Onder één maandbedrag valt alles wat bij een goede website hoort: de site zelf, het technische onderhoud, de zichtbaarheid in Google en de opvolging van aanvragen. Kleine aanpassingen die later nodig zijn horen bij het pakket.
              </p>
              <ul class="space-y-2 text-sm text-ink/70 mb-6">
                <li class="flex items-start gap-2"><span class="text-accent mt-1">&bull;</span> Maatwerk website die bij je bedrijf past</li>
                <li class="flex items-start gap-2"><span class="text-accent mt-1">&bull;</span> Google Bedrijfsprofiel ingericht en onderhouden</li>
                <li class="flex items-start gap-2"><span class="text-accent mt-1">&bull;</span> Aanvragen direct naar je telefoon via WhatsApp</li>
                <li class="flex items-start gap-2"><span class="text-accent mt-1">&bull;</span> Automatische review-verzoeken na elke klus</li>
                <li class="flex items-start gap-2"><span class="text-accent mt-1">&bull;</span> Hosting, domein en zakelijk e-mailadres</li>
              </ul>
              <span class="mt-auto text-sm font-bold text-ink group-hover:text-accent transition-colors inline-flex items-center gap-1">
                Meer over het pakket <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </span>
            </a>
          </FadeIn>

          <FadeIn delay={200}>
            <a href={stage0Offer.enabled ? stage0Offer.ctaUrl : "/webdesign/"} class="glass-card p-8 md:p-10 flex flex-col cursor-pointer group block h-full">
              <div class="w-10 h-10 rounded-lg bg-accent flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/><circle cx="12" cy="15" r="1.5" fill="currentColor"/></svg>
              </div>
              {stage0Offer.enabled ? (
                <>
                  <span class="text-xs font-mono uppercase tracking-widest text-ink/40 mb-2">Nu in {stage0Offer.month}</span>
                  <h3 class="text-2xl font-bold mb-3">Gratis website voor {bedrijvenLabel()}</h3>
                  <p class="text-ink/70 leading-relaxed mb-6">
                    Er zijn nog {spotsLabel()} over voor een volledige website die ik kosteloos maak. In ruil schrijven we na 90 dagen samen een case study waarin we de cijfers van voor en na naast elkaar zetten.
                  </p>
                  <span class="mt-auto text-sm font-bold text-ink group-hover:text-accent transition-colors inline-flex items-center gap-1">
                    Past dit bij jou? <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
                  </span>
                </>
              ) : (
                <>
                  <span class="text-xs font-mono uppercase tracking-widest text-ink/40 mb-2">Wat kost het</span>
                  <h3 class="text-2xl font-bold mb-3">Een vast maandbedrag</h3>
                  <p class="text-ink/70 leading-relaxed mb-6">
                    Eenmalig €497 setup, daarna €47 per maand. Daarvoor krijg je hosting, onderhoud, het Google Bedrijfsprofiel, lead-opvolging, review-verzoeken en kleine aanpassingen. Minimaal 12 maanden, daarna maand voor maand opzegbaar.
                  </p>
                  <span class="mt-auto text-sm font-bold text-ink group-hover:text-accent transition-colors inline-flex items-center gap-1">
                    Bekijk de voorwaarden <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
                  </span>
                </>
              )}
            </a>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- WERK SHOWCASE (full-bleed right) -->
    <section class="py-20 md:py-28 bg-canvas relative z-10 overflow-hidden">
      <div class="max-w-5xl mx-auto px-6 md:px-12 lg:px-16 mb-12 md:mb-16 relative z-10">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">Werk</span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
            Recente projecten
          </h2>
        </FadeIn>
      </div>

      <FadeIn delay={200}>
        <DraggableScroll client:visible className="pb-4 pl-6 md:pl-12 lg:pl-[max(1rem,calc((100vw-64rem)/2+1rem))]">
          {/* Live projects from data */}
          {projects.map(project => (
            <a
              href={`/project/${project.slug}/`}
              class="flex-shrink-0 w-[380px] md:w-[480px] lg:w-[560px] rounded-2xl border border-warm bg-white overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group block"
            >
              <div class="aspect-[16/10] bg-gradient-to-br from-canvas-alt to-canvas flex items-center justify-center overflow-hidden">
                {project.overviewMockup ? (
                  <img
                    src={project.overviewMockup}
                    alt={project.title}
                    width="1200"
                    height="750"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    draggable="false"
                  />
                ) : (
                  <span class="text-ink/50/40 text-sm">Preview</span>
                )}
              </div>
              <div class="p-5">
                {project.category === "Live" ? (
                  <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-accent text-white px-2 py-0.5 rounded-full mb-2">LIVE</span>
                ) : (
                  <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2 py-0.5 rounded-full mb-2">IN ONTWIKKELING</span>
                )}
                <h3 class="font-bold text-lg mb-1">{project.title}</h3>
                <p class="text-sm text-ink/50">{project.industry} · {project.location}</p>
              </div>
            </a>
          ))}

          {/* Demo sites */}
          <a
            href="https://demo-hovenier.knapgemaakt.nl"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-shrink-0 w-[380px] md:w-[480px] lg:w-[560px] rounded-2xl border border-warm bg-white overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group block"
          >
            <div class="aspect-[16/10] overflow-hidden bg-canvas-alt">
              <img
                src="/assets/projects/demo-hovenier.webp"
                alt="Demo website voor hoveniersbedrijf"
                width="2304"
                height="1536"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-5">
              <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2 py-0.5 rounded-full mb-2">DEMO</span>
              <h3 class="font-bold text-lg mb-1">Hovenier Demo</h3>
              <p class="text-sm text-ink/50">Demo website voor hoveniers</p>
            </div>
          </a>

          <a
            href="https://demo-elektricien.knapgemaakt.nl"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-shrink-0 w-[380px] md:w-[480px] lg:w-[560px] rounded-2xl border border-warm bg-white overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group block"
          >
            <div class="aspect-[16/10] overflow-hidden bg-canvas-alt">
              <img
                src="/assets/projects/demo-elektricien.webp"
                alt="Demo website voor elektricien"
                width="2304"
                height="1536"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-5">
              <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2 py-0.5 rounded-full mb-2">DEMO</span>
              <h3 class="font-bold text-lg mb-1">Elektricien Demo</h3>
              <p class="text-sm text-ink/50">Demo website voor elektriciens</p>
            </div>
          </a>

          {/* View all link */}
          <a
            href="/werk/"
            class="flex-shrink-0 w-[200px] md:w-[250px] mr-6 rounded-2xl border border-warm bg-canvas-alt flex flex-col items-center justify-center hover:border-accent transition-colors duration-300 group"
          >
            <span class="text-ink/50 group-hover:text-ink transition-colors font-bold mb-1">Bekijk alles</span>
            <span class="text-accent text-sm">Naar portfolio &rarr;</span>
          </a>
        </DraggableScroll>
      </FadeIn>
    </section>

    <!-- SOCIAL PROOF (hidden until real reviews are available) -->
    <!-- <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-canvas-alt relative z-10">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">Wat klanten zeggen</span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-12 md:mb-16">
            Ervaringen
          </h2>
        </FadeIn>
      </div>
    </section> -->

    <!-- BOTTOM CTA -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-ink text-canvas relative z-10 overflow-hidden">
      <div class="max-w-5xl mx-auto text-center relative z-10">
        <FadeIn>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight leading-tight mb-6">
            Klaar voor een website die wél werkt?
          </h2>
          <p class="text-canvas/60 text-lg mb-10 max-w-xl mx-auto">
            Plan een kennismaking. Vertel wat je bedrijf doet, ik kom met een concreet voorstel. Past het niet, dan zeg ik dat ook.
          </p>
          <a
            href="/aanvragen/"
            class="bg-accent text-white px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-accent/90 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
          >
            Plan een kennismaking
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </FadeIn>
      </div>
    </section>
  </main>
  <Footer hideCTA={true} />
</Layout>
