---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import FadeIn from "../../components/FadeIn.astro";
import FAQSection from "../../components/FAQSection.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServiceSchema from "../../components/seo/ServiceSchema.astro";

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "Automatisering", url: "https://knapgemaakt.nl/automatisering/" },
	{ name: "Weekoverzichten", url: "https://knapgemaakt.nl/automatisering/weekoverzichten/" }
];
---

<Layout
  title="Weekoverzicht van je bedrijf | Automatisch op maandagochtend | KNAP GEMAAKT."
  description="Elke maandagochtend een overzicht in je inbox van openstaande offertes, lopende klussen en onbetaalde facturen. Samengesteld uit je bestaande tools. Vanaf €39 per maand."
>
  <ServiceSchema
    name="Weekoverzicht automatisering"
    description="Elke maandagochtend een overzichtelijk rapport in je inbox: openstaande offertes, lopende klussen, openstaande facturen. Samengesteld uit Moneybird, agenda en CRM. Vanaf €39 per maand."
    serviceType="ITService"
    url="https://knapgemaakt.nl/automatisering/weekoverzichten/"
    price="39"
  />
  <main>
    <!-- Hero -->
    <section class="pt-32 pb-12 md:pt-40 md:pb-16 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <div class="mb-6">
          <Breadcrumb items={breadcrumbs} />
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-snug mb-6">
          Maandagochtend, overzicht in je mail
        </h1>
        <p class="text-lg md:text-xl text-ink/70 max-w-2xl leading-relaxed">
          Een weekoverzicht is een automatisering die elke maandagochtend een compact rapport in je inbox zet. Openstaande offertes, klussen deze week, facturen die nog binnen moeten komen. Allemaal uit je bestaande tools, op één plek. Zo begin je je week met een duidelijk hoofd.
        </p>
      </div>
    </section>

    <!-- Problem -->
    <section class="py-16 md:py-20 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-3xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">Het probleem</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-6">
            Je overzicht zit verspreid over meerdere plekken
          </h2>
          <div class="space-y-5 text-ink/70 leading-relaxed text-lg">
            <p>
              Je boekhouding weet wie betaald heeft. Je mail of offertesysteem heeft de laatste aanvragen. Je agenda heeft de klussen van deze week. Om een week overzicht op te bouwen ben je snel twintig minuten bezig met tabbladen wisselen.
            </p>
            <p>
              Een weekoverzicht pakt die gegevens uit je bestaande tools en zet ze in één mail. Geen nieuw systeem om in te richten, geen dashboard om in te loggen. Jij kiest op welk moment je 'm in je inbox wilt.
            </p>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- What's in it -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">Wat erin staat</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-10 md:mb-14">
            Vier blokken, elk met wat er deze week telt
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-2 gap-6 md:gap-8">
          <FadeIn delay={100}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <h3 class="font-bold text-lg mb-3">Openstaande offertes</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                Welke offertes heb je verstuurd waar nog geen reactie op is? Hoe oud zijn ze? Twee weken zonder reactie is meestal het moment om even te bellen. Dat zie je hier in één oogopslag.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <h3 class="font-bold text-lg mb-3">Klussen deze week</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                Uit je agenda: wie staat er op de planning, waar en voor wat. Handig om maandagochtend mentaal door te lopen, zodat je voorbereid aan de week begint.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={300}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <h3 class="font-bold text-lg mb-3">Openstaande facturen</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                Welke facturen staan nog open, welke zijn al betaald sinds vorige week. Zo zie je precies hoe de cashflow loopt zonder in Moneybird te duiken.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={400}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <h3 class="font-bold text-lg mb-3">Weekresultaat</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                Een korte samenvatting van vorige week: hoeveel klussen afgerond, hoeveel binnengehaald aan offertes, hoeveel reviews erbij. Ritme erin houden, zonder spreadsheet.
              </p>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-ink text-canvas">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-[5fr_7fr] gap-10 md:gap-16 items-start">
          <FadeIn>
            <span class="text-xs font-bold uppercase tracking-widest text-canvas/40 mb-4 block">Wat het kost</span>
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight leading-tight mb-6">
              Vanaf €39<br />per maand
            </h2>
            <p class="text-canvas/70 leading-relaxed">
              Je koppelt de tools die je al gebruikt. Vanaf de maand dat het rapport elke week bij je binnenvalt, betaal je het vaste bedrag.
            </p>
          </FadeIn>

          <FadeIn delay={100}>
            <div class="bg-canvas/5 rounded-xl p-6 md:p-8 border border-canvas/10">
              <h3 class="font-bold text-lg text-canvas mb-4">Werkt samen met</h3>
              <ul class="space-y-3 text-canvas/70 text-sm">
                <li class="flex gap-3"><span class="text-accent font-bold shrink-0">→</span><span>Boekhoudpakketten zoals Moneybird, e-Boekhouden, Exact en Snelstart voor facturen en offertes</span></li>
                <li class="flex gap-3"><span class="text-accent font-bold shrink-0">→</span><span>Offerte-tools zoals Simpul of Enveloop, als je die gebruikt in plaats van je boekhoudpakket</span></li>
                <li class="flex gap-3"><span class="text-accent font-bold shrink-0">→</span><span>Google Agenda of Outlook voor klussenplanning</span></li>
                <li class="flex gap-3"><span class="text-accent font-bold shrink-0">→</span><span>Google Business Profile voor nieuwe reviews van de afgelopen week</span></li>
                <li class="flex gap-3"><span class="text-accent font-bold shrink-0">→</span><span>Gebruik je iets anders? Even overleggen, meestal kan er een koppeling bij</span></li>
              </ul>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-3xl mx-auto">
        <FadeIn>
          <FAQSection faqs={[
            {
              question: "Kan ik kiezen welke blokken erin staan?",
              answer: "Ja. Misschien heb je geen behoefte aan weekresultaten, of wil je een extra blok voor social media-cijfers. De standaard is een startpunt dat voor de meeste ondernemers werkt. Je past hem aan zodra je ziet wat je echt elke week gebruikt."
            },
            {
              question: "Kan ik een ander moment dan maandagochtend kiezen?",
              answer: "Zeker. Sommige ondernemers willen hem vrijdagmiddag (om de week af te sluiten), anderen zondagavond (om alvast voorbereid te zijn). Tijdstip en dag kies jij. De automatisering draait op de achtergrond ongeacht wanneer je zelf werkt."
            },
            {
              question: "Wat als mijn data over meerdere e-mailadressen of accounts verspreid zit?",
              answer: "Dat komt vaker voor. We kunnen meerdere bronnen koppelen aan één rapport, zolang jij de juiste toegang hebt. Werk je met een boekhouder die alleen in zijn eigen systeem werkt? Dan bespreken we even hoe we daar toegang tot krijgen."
            },
            {
              question: "Is dit een vervanging voor mijn CRM?",
              answer: "Nee, dit is een samenvatting van wat je tools al weten. Het doel is overzicht, niet registratie. Heb je geen CRM en werkt alles op mail en spreadsheets? Dan helpt dit rapport je structuur te zien zonder dat je nog een systeem moet leren."
            }
          ]} />
        </FadeIn>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-3xl mx-auto text-center">
        <FadeIn>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
            Begint je week nu rommelig?
          </h2>
          <p class="text-ink/70 text-lg leading-relaxed mb-8">
            Plan een gesprek in. Vertel welke tools je gebruikt en wat je elke maandagochtend wilt weten. Ik laat zien hoe een eerste versie eruit kan zien.
          </p>
          <a
            href="/aanvragen/?onderwerp=automatisering"
            class="bg-ink text-canvas px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
          >
            Plan een gesprek in
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </FadeIn>
      </div>
    </section>
  </main>
  <Footer hideCTA={true} />
</Layout>
