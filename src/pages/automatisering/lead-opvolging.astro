---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import FadeIn from "../../components/FadeIn.astro";
import FAQSection from "../../components/FAQSection.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServiceSchema from "../../components/seo/ServiceSchema.astro";

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "Automatisering", url: "https://knapgemaakt.nl/automatisering/" },
	{ name: "Lead-opvolging", url: "https://knapgemaakt.nl/automatisering/lead-opvolging/" }
];
---

<Layout
  title="Lead-opvolging automatisering | Reageer binnen een minuut | KNAP GEMAAKT."
  description="Elke aanvraag wordt direct opgevolgd. Je klant krijgt een bevestiging, jij krijgt een melding op je telefoon. Vanaf €49 per maand. Inbegrepen in Pakket Compleet."
>
  <ServiceSchema
    name="Lead-opvolging automatisering"
    description="Automatische opvolging van elke aanvraag via je contactformulier. Je klant krijgt direct een bevestiging, jij krijgt een WhatsApp-melding op je telefoon. Vanaf €49 per maand, of inbegrepen in Pakket Compleet."
    serviceType="ITService"
    url="https://knapgemaakt.nl/automatisering/lead-opvolging/"
    price="49"
  />
  <main>
    <!-- Hero -->
    <section class="pt-32 pb-12 md:pt-40 md:pb-16 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <div class="mb-6">
          <Breadcrumb items={breadcrumbs} />
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-snug mb-6">
          Geen aanvraag meer gemist
        </h1>
        <p class="text-lg md:text-xl text-ink/70 max-w-2xl leading-relaxed">
          Lead-opvolging is een automatisering die elke aanvraag via je contactformulier direct oppakt. Je klant krijgt binnen een minuut een nette bevestiging, jij krijgt een WhatsApp-melding op je telefoon, en de aanvraag staat in één overzicht. Zo pak je elke kans, ook als je aan het werk bent.
        </p>
      </div>
    </section>

    <!-- The real problem -->
    <section class="py-16 md:py-20 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-3xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">Het probleem</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-6">
            Je bent aan het werk, je telefoon gaat
          </h2>
          <div class="space-y-5 text-ink/70 leading-relaxed text-lg">
            <p>
              Iemand vult 's avonds je contactformulier in. Jij zit op de bank. Morgen lees je de mail tussen het ontbijt door, je belt later die dag terug, en dan is er al een ander langs geweest. Zo verlies je werk zonder dat je weet hoe.
            </p>
            <p>
              Onderzoek van Harvard Business Review: bedrijven die binnen 5 minuten reageren op een aanvraag, converteren 21 keer beter dan bedrijven die na een uur bellen. Eén uur wachten halveert al je kans. Als ondernemer kun je niet 24 uur voor je mail zitten. Daarom laat je het regelen.
            </p>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- How the automation works -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-4 block">Hoe het werkt</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-10 md:mb-14">
            Drie dingen die tegelijk gebeuren
          </h2>
        </FadeIn>

        <div class="grid md:grid-cols-3 gap-6 md:gap-8">
          <FadeIn delay={100}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="text-xs font-mono uppercase tracking-widest text-accent mb-3">01</div>
              <h3 class="font-bold text-lg mb-3">Klant krijgt bevestiging</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                Binnen een minuut valt er een nette bevestigingsmail binnen. In jouw toon, met jouw naam. Geen standaard "Uw bericht is ontvangen". Je klant weet dat 'ie in goede handen is.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="text-xs font-mono uppercase tracking-widest text-accent mb-3">02</div>
              <h3 class="font-bold text-lg mb-3">Jij krijgt een appje</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                WhatsApp-melding op je telefoon met de naam, het nummer en waar het over gaat. Zo kun je vanaf de steiger even bellen, of het bewust laten liggen tot de lunch. Jij bepaalt.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={300}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="text-xs font-mono uppercase tracking-widest text-accent mb-3">03</div>
              <h3 class="font-bold text-lg mb-3">Aanvraag in één overzicht</h3>
              <p class="text-ink/70 text-sm leading-relaxed">
                Alles wordt automatisch opgeslagen met datum, tijd en inhoud. Je hoeft niet meer door mailtjes te spitten of losse appjes terug te vinden. Later terugkijken kan gewoon.
              </p>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- What it costs + positioning -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-ink text-canvas">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-[5fr_7fr] gap-10 md:gap-16 items-start">
          <FadeIn>
            <span class="text-xs font-bold uppercase tracking-widest text-canvas/40 mb-4 block">Wat het kost</span>
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight leading-tight mb-6">
              Vanaf €49<br />per maand
            </h2>
            <p class="text-canvas/70 leading-relaxed">
              Geen grote investering vooraf. Je betaalt vanaf de maand dat de automatisering draait. Opzeggen kan op elk moment.
            </p>
          </FadeIn>

          <FadeIn delay={100}>
            <div class="bg-canvas/5 rounded-xl p-6 md:p-8 border border-canvas/10">
              <div class="flex items-start gap-3 mb-4">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
                <h3 class="font-bold text-lg text-canvas">Gratis in Pakket Compleet</h3>
              </div>
              <p class="text-canvas/70 text-sm leading-relaxed mb-4">
                Heb je Pakket Compleet (€149 per maand)? Dan zit lead-opvolging erbij in. Ook de Google Reviews-automatisering en een kwartaalgesprek zitten in dat pakket.
              </p>
              <a href="/pakketten/" class="text-accent font-bold text-sm hover:underline inline-flex items-center gap-1">
                Bekijk de pakketten <span>&rarr;</span>
              </a>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-3xl mx-auto">
        <FadeIn>
          <FAQSection faqs={[
            {
              question: "Hoe snel valt de bevestiging binnen bij mijn klant?",
              answer: "Meestal binnen 30 seconden. De automatisering stuurt de mail direct na het inzenden van het formulier. Jouw WhatsApp-melding komt vaak nog sneller aan. Ruim binnen de 5 minuten waarin je volgens Harvard de meeste kans hebt om de klant te winnen."
            },
            {
              question: "Wat als ik liever geen WhatsApp wil op mijn zakelijke telefoon?",
              answer: "Dan regel ik dat je de melding via SMS of pushbericht krijgt. Of allebei. Veel ZZP'ers kiezen voor WhatsApp omdat je hem toch al open hebt, maar er is geen enkele verplichting. We kiezen de manier die bij jouw werkdag past."
            },
            {
              question: "Mijn site heeft nog geen contactformulier. Kan dat?",
              answer: "Zeker. Als je site door mij is gemaakt staat er al een formulier op. Is je site door iemand anders gemaakt, dan voeg ik een eenvoudig formulier toe dat met deze automatisering samenwerkt. Dat kost wat extra opzettijd, maar geen extra maandbedrag."
            },
            {
              question: "Kan ik de tekst van de bevestigingsmail zelf aanpassen?",
              answer: "Ja. We schrijven de eerste versie samen, zodat de toon klopt met hoe je normaal met klanten praat. Wil je later iets aanpassen, dan regel ik dat voor je. Het hoort bij de maandprijs, je hoeft niet zelf in code te duiken."
            },
            {
              question: "Wat gebeurt er met de aanvragen in mijn overzicht?",
              answer: "Ze blijven bewaard zolang je de automatisering afneemt. Je kunt ze exporteren naar een Excel-bestand als je ze ergens anders wilt bewaren. Stop je met de automatisering? Dan stuur ik je alle aanvragen netjes toe voor je eigen administratie."
            }
          ]} />
        </FadeIn>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-3xl mx-auto text-center">
        <FadeIn>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
            Eerst even sparren of dit bij je past?
          </h2>
          <p class="text-ink/70 text-lg leading-relaxed mb-8">
            Plan een gesprek in. Ik kijk met je mee naar hoe aanvragen nu bij je binnenkomen en wat dit je concreet gaat schelen.
          </p>
          <a
            href="/aanvragen/?onderwerp=automatisering"
            class="bg-ink text-canvas px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
          >
            Plan een gesprek in
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </FadeIn>
      </div>
    </section>
  </main>
  <Footer hideCTA={true} />
</Layout>
