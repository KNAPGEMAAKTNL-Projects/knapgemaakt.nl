---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import FadeIn from "../../components/FadeIn.astro";
import FAQSection from "../../components/FAQSection.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "ICT Diensten", url: "https://knapgemaakt.nl/ict-diensten/" },
	{ name: "E-mail Hosting", url: "https://knapgemaakt.nl/ict-diensten/email-hosting/" }
];
---

<Layout
  title="E-mail Hosting | Zakelijke E-mail op Eigen Domein | KNAP GEMAAKT."
  description="Zakelijke e-mail hosting op je eigen domeinnaam. Geen prijs per gebruiker, maar per opslagruimte. Vanaf €5 per maand, inclusief spamfilter en migratie."
>
  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <div class="mb-6">
          <Breadcrumb items={breadcrumbs} />
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-snug mb-6">
          Zakelijke e-mail op je eigen domein
        </h1>
        <p class="text-lg md:text-xl text-ink-secondary max-w-2xl leading-relaxed">
          Professionele e-mail op je eigen domeinnaam. Niet per persoon afgerekend, maar op basis van wat je daadwerkelijk gebruikt. Inclusief migratie, spamfilter en persoonlijk beheer.
        </p>
      </div>
    </section>

    <!-- Section 1: The Problem (Education) -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
            <div>
              <div class="w-12 h-12 rounded-xl bg-ink flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
                Wat is e-mail hosting eigenlijk?
              </h2>
              <p class="text-ink-secondary leading-relaxed mb-4">
                E-mail werkt anders dan de meeste mensen denken. Je website en je e-mail zijn twee compleet losse dingen. Ze kunnen bij dezelfde partij staan, maar dat hoeft niet.
              </p>
              <p class="text-ink-secondary leading-relaxed">
                Vergelijk het met een brievenbus. Je website is je etalage. Je e-mail is je brievenbus. Die hoeven niet aan hetzelfde pand te hangen. Toch koppelen de meeste hostingpartijen ze aan elkaar. Handig voor hen, want zo maak je het lastig om over te stappen. Minder handig voor jou.
              </p>
            </div>
            <div>
              <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm">
                <h3 class="font-bold text-lg mb-4">Hoe werkt dat technisch?</h3>
                <p class="text-ink-secondary leading-relaxed mb-4">
                  Als iemand een mail stuurt naar info@jouwbedrijf.nl, kijkt het internet in een soort telefoonboek. Daar staat: "mail voor dit domein moet naar deze server." Dat zijn je <strong class="text-ink">MX-records</strong>.
                </p>
                <p class="text-ink-secondary leading-relaxed mb-4">
                  Die instellingen kun je aanpassen. Je kunt je e-mail dus bij partij A laten staan en je website bij partij B. Of allebei bij dezelfde. Het maakt technisch niet uit.
                </p>
                <p class="text-ink-secondary leading-relaxed">
                  Het punt is: je hebt die keuze. De meeste hostingbedrijven vertellen je dat niet, want ze verdienen er meer aan als alles bij hen blijft.
                </p>
              </div>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Section 2: What KNAP GEMAAKT. Offers -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
            Dit zit er allemaal bij
          </h2>
          <p class="text-ink-secondary leading-relaxed mb-10 max-w-2xl">
            Professionele e-mail op je eigen domeinnaam, zonder dat je zelf iets technisch hoeft te regelen. Ik zet alles op en verplaats je bestaande mail.
          </p>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Feature 1 -->
            <div class="bg-canvas-alt rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <h3 class="font-bold mb-2">IMAP e-mail</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Je mail staat op een server en is overal beschikbaar. Telefoon, laptop, tablet. Alles synchroon, altijd up-to-date.
              </p>
            </div>

            <!-- Feature 2 -->
            <div class="bg-canvas-alt rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
              </div>
              <h3 class="font-bold mb-2">Werkt met alles</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Outlook, Apple Mail, de Gmail-app op je telefoon, webmail in de browser. Net wat je prettig vindt.
              </p>
            </div>

            <!-- Feature 3 -->
            <div class="bg-canvas-alt rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
              </div>
              <h3 class="font-bold mb-2">Spamfilter</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Ongewenste mail wordt automatisch tegengehouden voordat het je inbox bereikt. Scheelt een hoop opruimwerk.
              </p>
            </div>

            <!-- Feature 4 -->
            <div class="bg-canvas-alt rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              </div>
              <h3 class="font-bold mb-2">Belandt in de inbox</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Jouw mails belanden in de inbox van je klant, niet in hun spammap. Ik stel de juiste beveiligingsinstellingen in zodat mailservers weten dat jij echt jij bent.
              </p>
            </div>

            <!-- Feature 5 -->
            <div class="bg-canvas-alt rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
              </div>
              <h3 class="font-bold mb-2">Overstappen zonder gedoe</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Ik verplaats je bestaande e-mails van je oude aanbieder. Mappen, contacten, alles.
              </p>
            </div>

            <!-- Feature 6 -->
            <div class="bg-canvas-alt rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-lg bg-ink flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-canvas" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </div>
              <h3 class="font-bold mb-2">Monitoring</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Ik houd je opslaggebruik bij en geef je een seintje als het tijd wordt om op te ruimen of op te schalen.
              </p>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Section 3: Pricing -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
            Prijzen
          </h2>
          <p class="text-ink-secondary leading-relaxed mb-3 max-w-2xl">
            Je betaalt niet per e-mailadres. Je betaalt voor opslagruimte. Of je nu twee adressen hebt of tien: zolang het in je opslag past, blijft de prijs hetzelfde.
          </p>
          <p class="text-ink-secondary leading-relaxed mb-10 max-w-2xl">
            Dat is het verschil met de meeste aanbieders. Bij Google Workspace of Microsoft 365 betaal je per persoon. Bij mij betaal je voor wat je gebruikt.
          </p>

          <div class="grid md:grid-cols-3 gap-6">
            <!-- Basis -->
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm flex flex-col">
              <div class="mb-6">
                <h3 class="font-bold text-lg mb-1">Basis</h3>
                <p class="text-ink-secondary text-sm">ZZP'ers en kleine bedrijven met 1-3 personen</p>
              </div>
              <div class="mb-6">
                <span class="text-4xl font-bold tracking-tight">&euro;5</span>
                <span class="text-ink-secondary">/maand</span>
              </div>
              <ul class="space-y-3 mb-8 flex-grow">
                {["5 GB opslagruimte", "Onbeperkt e-mailadressen", "Spamfilter inbegrepen", "Belandt in de inbox", "Overstappen zonder gedoe", "Monitoring"].map((item) => (
                  <li class="flex items-center gap-3 text-ink-secondary text-sm">
                    <div class="w-2 h-2 rounded-full bg-accent shrink-0"></div>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href="/aanvragen/?onderwerp=email-hosting"
                class="bg-ink text-canvas px-6 py-3 rounded-lg font-bold text-sm hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-2 group w-full"
              >
                Gesprek aanvragen
                <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>

            <!-- Uitgebreid -->
            <div class="bg-canvas rounded-xl p-6 md:p-8 border-2 border-accent flex flex-col relative">
              <div class="absolute -top-3 left-6 bg-accent text-canvas text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                Populair
              </div>
              <div class="mb-6">
                <h3 class="font-bold text-lg mb-1">Uitgebreid</h3>
                <p class="text-ink-secondary text-sm">Bedrijven die veel mailen of meer personeel hebben</p>
              </div>
              <div class="mb-6">
                <span class="text-4xl font-bold tracking-tight">&euro;10</span>
                <span class="text-ink-secondary">/maand</span>
              </div>
              <ul class="space-y-3 mb-8 flex-grow">
                {["15 GB opslagruimte", "Onbeperkt e-mailadressen", "Spamfilter inbegrepen", "Belandt in de inbox", "Overstappen zonder gedoe", "Monitoring"].map((item) => (
                  <li class="flex items-center gap-3 text-ink-secondary text-sm">
                    <div class="w-2 h-2 rounded-full bg-accent shrink-0"></div>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href="/aanvragen/?onderwerp=email-hosting"
                class="bg-accent text-canvas px-6 py-3 rounded-lg font-bold text-sm hover:bg-accent/90 transition-colors duration-300 inline-flex items-center justify-center gap-2 group w-full"
              >
                Gesprek aanvragen
                <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>

            <!-- Op maat -->
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm flex flex-col">
              <div class="mb-6">
                <h3 class="font-bold text-lg mb-1">Op maat</h3>
                <p class="text-ink-secondary text-sm">Voor wie meer nodig heeft.</p>
              </div>
              <div class="mb-6">
                <span class="text-2xl font-bold tracking-tight">Op aanvraag</span>
              </div>
              <ul class="space-y-3 mb-8 flex-grow">
                {["Meer opslagruimte", "Onbeperkt e-mailadressen", "Spamfilter inbegrepen", "Belandt in de inbox", "Overstappen zonder gedoe", "Monitoring"].map((item) => (
                  <li class="flex items-center gap-3 text-ink-secondary text-sm">
                    <div class="w-2 h-2 rounded-full bg-accent shrink-0"></div>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href="/aanvragen/?onderwerp=email-hosting"
                class="bg-ink text-canvas px-6 py-3 rounded-lg font-bold text-sm hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-2 group w-full"
              >
                Gesprek aanvragen
                <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Section 4: Storage Explainer -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
            <div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
                Hoeveel opslag heb ik nodig?
              </h2>
              <p class="text-ink-secondary leading-relaxed mb-4">
                Getallen als "5 GB" zeggen de meeste mensen niks. Dus hier een overzicht van wat er in de praktijk in past.
              </p>
              <p class="text-ink-secondary leading-relaxed mb-4">
                Een gemiddelde ZZP'er stuurt en ontvangt zo'n 10 tot 30 mails per dag. Meestal tekst, af en toe een bijlage. Dat komt neer op ruwweg een halve tot een gigabyte per jaar.
              </p>
              <p class="text-ink-secondary leading-relaxed">
                Met 5 GB zit je dus makkelijk vijf jaar goed met een enkel mailadres. Zelfs met drie mailboxen heb je met het Basis-abonnement drie tot vier jaar ruimte voordat het een gesprekspunt wordt.
              </p>
            </div>
            <div>
              <div class="bg-canvas-alt rounded-xl border border-warm overflow-hidden">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-warm">
                      <th class="text-left p-4 font-bold text-xs uppercase tracking-wider">Type e-mail</th>
                      <th class="text-left p-4 font-bold text-xs uppercase tracking-wider">Grootte</th>
                      <th class="text-left p-4 font-bold text-xs uppercase tracking-wider">Past in 5 GB</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="border-b border-warm/50">
                      <td class="p-4 text-ink-secondary">Alleen tekst</td>
                      <td class="p-4 text-ink-secondary">10-20 KB</td>
                      <td class="p-4 font-bold">~500.000</td>
                    </tr>
                    <tr class="border-b border-warm/50">
                      <td class="p-4 text-ink-secondary">Met PDF-factuur</td>
                      <td class="p-4 text-ink-secondary">200-500 KB</td>
                      <td class="p-4 font-bold">~16.000</td>
                    </tr>
                    <tr class="border-b border-warm/50">
                      <td class="p-4 text-ink-secondary">Met een foto</td>
                      <td class="p-4 text-ink-secondary">2-5 MB</td>
                      <td class="p-4 font-bold">~1.600</td>
                    </tr>
                    <tr>
                      <td class="p-4 text-ink-secondary">Met vijf foto's</td>
                      <td class="p-4 text-ink-secondary">~15 MB</td>
                      <td class="p-4 font-bold">~330</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <p class="text-ink-secondary text-sm mt-4 leading-relaxed">
                De meeste ondernemers sturen geen vijf foto's per mail. Facturen, offertes en gewone berichten vormen het grootste deel. Daar heb je enorm veel ruimte voor.
              </p>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Section 5: What Happens When Full -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
            Wat als mijn opslag vol raakt?
          </h2>
          <p class="text-ink-secondary leading-relaxed mb-10 max-w-2xl">
            Logische vraag. Kort antwoord: daar hoef je je geen zorgen over te maken. Ik houd het in de gaten en grijp in voordat het een probleem wordt.
          </p>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-canvas rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-bold">1</span>
              </div>
              <h3 class="font-bold mb-2 text-sm uppercase tracking-wider">Melding</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Ik monitor je opslag. Je krijgt ruim op tijd een seintje, lang voordat mails gaan stuiteren.
              </p>
            </div>

            <div class="bg-canvas rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-bold">2</span>
              </div>
              <h3 class="font-bold mb-2 text-sm uppercase tracking-wider">Opruimen</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Oude nieuwsbrieven, reclamemail, bijlagen van jaren geleden. Daar zit vaak genoeg ruimte in om weer lucht te krijgen.
              </p>
            </div>

            <div class="bg-canvas rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-bold">3</span>
              </div>
              <h3 class="font-bold mb-2 text-sm uppercase tracking-wider">Archiveren</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Oude mails kunnen naar je computer worden gedownload. Dan zijn ze van de server af, maar nog steeds doorzoekbaar op je laptop.
              </p>
            </div>

            <div class="bg-canvas rounded-xl p-6 border border-warm">
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center mb-4">
                <span class="text-accent font-bold">4</span>
              </div>
              <h3 class="font-bold mb-2 text-sm uppercase tracking-wider">Opschalen</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Van Basis naar Uitgebreid is een simpele stap. Drie keer zoveel ruimte, geen gedoe met verhuizen.
              </p>
            </div>
          </div>

          <p class="text-ink-secondary leading-relaxed mt-8 max-w-2xl">
            Kort gezegd: ik houd het bij. Jij mailt gewoon door.
          </p>
        </FadeIn>
      </div>
    </section>

    <!-- Section 6: Competitor Comparison -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
            Wat betaal je elders?
          </h2>
          <p class="text-ink-secondary leading-relaxed mb-10 max-w-2xl">
            De meeste aanbieders rekenen per gebruiker. Heb je meerdere mailadressen nodig, dan loopt het snel op. Bij mij betaal je voor opslag, en je e-mail staat los van je website. Wil je ooit overstappen met je site? Dan hoef je je mail niet mee te slepen.
          </p>

          <div class="bg-canvas-alt rounded-xl border border-warm overflow-hidden mb-8">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-warm">
                    <th class="text-left p-4 md:p-5 font-bold text-xs uppercase tracking-wider">Aanbieder</th>
                    <th class="text-left p-4 md:p-5 font-bold text-xs uppercase tracking-wider">Per maand</th>
                    <th class="text-left p-4 md:p-5 font-bold text-xs uppercase tracking-wider">3 personen</th>
                    <th class="text-left p-4 md:p-5 font-bold text-xs uppercase tracking-wider">Model</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-warm/50">
                    <td class="p-4 md:p-5 text-ink-secondary">Google Workspace</td>
                    <td class="p-4 md:p-5 text-ink-secondary">&euro;6,90 / gebruiker</td>
                    <td class="p-4 md:p-5 text-ink-secondary">&euro;20,70</td>
                    <td class="p-4 md:p-5 text-ink-secondary">Per gebruiker</td>
                  </tr>
                  <tr class="border-b border-warm/50">
                    <td class="p-4 md:p-5 text-ink-secondary">Microsoft 365 Basic</td>
                    <td class="p-4 md:p-5 text-ink-secondary">&euro;6,00 / gebruiker</td>
                    <td class="p-4 md:p-5 text-ink-secondary">&euro;18,00</td>
                    <td class="p-4 md:p-5 text-ink-secondary">Per gebruiker</td>
                  </tr>
                  <tr class="border-b border-warm/50">
                    <td class="p-4 md:p-5 text-ink-secondary">Nederlandse hoster</td>
                    <td class="p-4 md:p-5 text-ink-secondary">&euro;5-6 / domein</td>
                    <td class="p-4 md:p-5 text-ink-secondary">&euro;5-6</td>
                    <td class="p-4 md:p-5 text-ink-secondary">Gebundeld</td>
                  </tr>
