---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import FadeIn from "../../components/FadeIn.astro";
import FAQSection from "../../components/FAQSection.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "ICT Diensten", url: "https://knapgemaakt.nl/ict-diensten/" },
	{ name: "Automatisering", url: "https://knapgemaakt.nl/ict-diensten/automatisering/" }
];
---

<Layout
  title="Automatisering & AI voor Ondernemers | KNAP GEMAAKT."
  description="Automatiseer terugkerende taken met AI en slimme workflows. Offertebevestigingen, factuurherinneringen, reviews verzamelen, WhatsApp-opvolging. KNAP GEMAAKT. regelt het."
>
  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <div class="mb-6">
          <Breadcrumb items={breadcrumbs} />
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-snug mb-6">
          Automatisering & AI
        </h1>
        <p class="text-lg md:text-xl text-ink-secondary max-w-2xl leading-relaxed">
          Je besteedt uren per week aan dingen die ook automatisch kunnen. Bevestigingsmails, factuurherinneringen, klantopvolging, overzichten bijhouden. Ik bouw workflows die dat voor je overnemen, zodat jij je kunt richten op je vak.
        </p>
      </div>
    </section>

    <!-- Concrete examples -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
            Wat kan er allemaal?
          </h2>
          <p class="text-ink-secondary leading-relaxed mb-10 max-w-2xl">
            Dit zijn voorbeelden van automatiseringen die ik voor ondernemers kan bouwen. Geen toekomstmuziek, dit werkt nu al.
          </p>
        </FadeIn>

        <div class="grid md:grid-cols-3 gap-8">
          <FadeIn>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 17a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9.5C2 7 4 5 6.5 5H18c2.2 0 4 1.8 4 4v8Z"/><polyline points="15 9 18 9 18 11"/><path d="M6.5 5C9 5 11 7 11 9.5V17a2 2 0 0 1-2 2v0"/><line x1="6" x2="7" y1="10" y2="10"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-3">Leads automatisch opvolgen</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Iemand vult je contactformulier in. Diegene krijgt direct een nette bevestiging, jij krijgt een melding op je telefoon, en de aanvraag staat automatisch in je overzicht. Bedrijven die binnen 5 minuten reageren converteren 21x beter.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={100}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-3">Factuurherinneringen</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Openstaande facturen worden automatisch opgepikt. Je klant krijgt een vriendelijke herinnering via e-mail of WhatsApp. Geen handmatig inloggen, geen vergeten facturen. Scheelt je zo 3 tot 4 uur per week.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-3">AI content maken</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                AI schrijft social media posts op basis van je werk. Foto van een afgerond project? Daar komt automatisch een LinkedIn-post, Instagram-caption en Facebook-bericht uit. Met hashtags en al.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={300}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-3">Reviews verzamelen</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Na een afgeronde klus krijgt je klant automatisch een vriendelijk berichtje met de vraag om een Google review. Geen ongemakkelijk telefoontje, en je reviews groeien vanzelf.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={400}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-3">WhatsApp-opvolging</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Klus afgerond? Automatisch bericht via WhatsApp: bedankt, hoe was het, en een link om een review achter te laten. Of een herinnering voor een vervolgafspraak. WhatsApp heeft 98% open rate.
              </p>
            </div>
          </FadeIn>

          <FadeIn delay={500}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              </div>
              <h3 class="font-bold text-lg mb-3">Weekoverzichten</h3>
              <p class="text-ink-secondary text-sm leading-relaxed">
                Elke maandagochtend in je inbox: een overzicht van openstaande offertes, lopende projecten en facturen die nog betaald moeten worden. Automatisch samengesteld uit je bestaande tools.
              </p>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
            <div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
                Mijn werkwijze
              </h2>
              <p class="text-ink-secondary leading-relaxed mb-6">
                Ik kijk mee met hoe je dagelijks werkt. Waar stuur je steeds dezelfde mail? Waar vergeet je een stap? Waar ben je een half uur kwijt aan iets dat ook automatisch kan? Dat zijn de plekken waar ik begin.
              </p>
              <p class="text-ink-secondary leading-relaxed mb-6">
                De automatiseringen werken samen met de tools die je al gebruikt. Je e-mail, je agenda, Moneybird, WhatsApp. Er komt geen nieuw systeem bij dat je moet leren.
              </p>
              <p class="text-ink-secondary leading-relaxed">
                Taken die nu handmatig gaan, gaan straks automatisch. Dat maakt tijd vrij voor werk dat er echt toe doet.
              </p>
            </div>
            <div>
              <div class="bg-canvas-alt rounded-xl p-6 md:p-8 border border-warm">
                <h3 class="font-bold text-lg mb-4">Hoe we starten</h3>
                <ul class="space-y-4">
                  {[
                    "We lopen samen je werkdag door. Welke taken herhalen zich, waar gaat tijd verloren?",
                    "Ik breng de workflows in kaart en schrijf uit wat er automatisch kan.",
                    "We beginnen met één workflow die meteen tijd bespaart.",
                    "Daarna bouwen we verder. Workflow voor workflow."
                  ].map((step, i) => (
                    <li class="flex items-start gap-3 text-ink-secondary">
                      <span class="w-6 h-6 rounded-full bg-ink text-canvas text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">
                        {i + 1}
                      </span>
                      <span>{step}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Before/after scenarios -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
            Voor en na
          </h2>
          <p class="text-ink-secondary leading-relaxed mb-10 max-w-2xl">
            Herken je dit? Zo ziet het eruit als je het slim aanpakt.
          </p>
        </FadeIn>

        <div class="grid sm:grid-cols-2 gap-6">
          <FadeIn>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60">Nieuwe aanvraag</span>
              </div>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <span class="text-ink-secondary/40 text-sm font-bold shrink-0 mt-0.5">Nu:</span>
                  <p class="text-ink-secondary text-sm">Mailtje binnengekomen, zit ergens in je inbox. Moet je vanavond maar even beantwoorden. Vergeet je soms.</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-accent text-sm font-bold shrink-0 mt-0.5">Straks:</span>
                  <p class="text-ink-secondary text-sm">Klant krijgt direct een nette bevestiging. Jij krijgt een melding op je telefoon. De aanvraag staat al in je overzicht.</p>
                </div>
              </div>
            </div>
          </FadeIn>

          <FadeIn delay={100}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60">Reviews verzamelen</span>
              </div>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <span class="text-ink-secondary/40 text-sm font-bold shrink-0 mt-0.5">Nu:</span>
                  <p class="text-ink-secondary text-sm">Project afgerond, klant is blij. Maar je vergeet om een review te vragen. Of je vindt het ongemakkelijk.</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-accent text-sm font-bold shrink-0 mt-0.5">Straks:</span>
                  <p class="text-ink-secondary text-sm">Een paar dagen later krijgt je klant automatisch een bericht via WhatsApp met een link naar je Google reviews.</p>
                </div>
              </div>
            </div>
          </FadeIn>

          <FadeIn delay={200}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60">Social media</span>
              </div>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <span class="text-ink-secondary/40 text-sm font-bold shrink-0 mt-0.5">Nu:</span>
                  <p class="text-ink-secondary text-sm">Je weet dat je meer zou moeten posten, maar je komt er niet aan toe. En als je het doet, kost het een uur om iets fatsoenlijks te schrijven.</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-accent text-sm font-bold shrink-0 mt-0.5">Straks:</span>
                  <p class="text-ink-secondary text-sm">Je stuurt een foto van je werk. AI maakt er posts van voor LinkedIn, Instagram en Facebook. Met tekst, hashtags en al. Jij keurt het goed, de rest gaat automatisch.</p>
                </div>
              </div>
            </div>
          </FadeIn>

          <FadeIn delay={300}>
            <div class="bg-canvas rounded-xl p-6 md:p-8 border border-warm h-full">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60">Openstaande facturen</span>
              </div>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <span class="text-ink-secondary/40 text-sm font-bold shrink-0 mt-0.5">Nu:</span>
                  <p class="text-ink-secondary text-sm">Je moet inloggen in Moneybird om te checken wie nog niet betaald heeft. Doe je als je eraan denkt.</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-accent text-sm font-bold shrink-0 mt-0.5">Straks:</span>
                  <p class="text-ink-secondary text-sm">Openstaande facturen worden automatisch opgepikt. Je klant krijgt een herinnering, jij krijgt een overzicht. Zonder in te loggen.</p>
                </div>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <FadeIn>
    <FAQSection faqs={[
      {
        question: "Wat voor taken kun je automatiseren?",
        answer: "Alles wat je steeds opnieuw handmatig doet: facturen versturen, afspraken bevestigen, leads opvolgen, data overzetten tussen systemen. Als je het kunt uitleggen, kan het waarschijnlijk geautomatiseerd worden."
      },
      {
        question: "Welke tools gebruik je daarvoor?",
        answer: "Vooral n8n en Cloudflare Workers. Dat zijn betrouwbare platforms die goed samenwerken met de tools die je al gebruikt, zoals je boekhoudsoftware, e-mail of CRM."
      },
      {
        question: "Wat kost automatisering?",
        answer: "Dat verschilt per project. Een simpele e-mailautomatisering kan al in een paar uur staan. Complexere workflows met meerdere systemen kosten meer tijd. Ik geef altijd vooraf een inschatting."
      },
      {
        question: "Kan ik het zelf aanpassen achteraf?",
        answer: "Dat hangt af van de complexiteit. Eenvoudige workflows leer ik je beheren. Bij technischere oplossingen regel ik aanpassingen voor je. Je zit nooit vast aan iets dat je niet begrijpt."
      }
    ]} />
    </FadeIn>

    <!-- CTA -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16">
      <div class="max-w-3xl mx-auto text-center">
        <FadeIn>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
            Welke taken kosten jou de meeste tijd?
          </h2>
          <p class="text-ink-secondary text-lg leading-relaxed mb-8">
            Ieder bedrijf werkt anders. Vertel me wat je dagelijks doet, dan zoek ik uit wat er automatisch kan. Gewoon even bellen, kijken of het past.
          </p>
          <a
            href="/aanvragen/?onderwerp=automatisering"
            class="bg-ink text-canvas px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
          >
            Plan een gesprek in
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </FadeIn>
      </div>
    </section>
  </main>
  <Footer hideCTA={true} />
</Layout>
