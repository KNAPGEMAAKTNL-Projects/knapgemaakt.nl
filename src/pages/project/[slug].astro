---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import FadeIn from "../../components/FadeIn.astro";
import { getAllProjects } from "../../data/projects";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";

export const prerender = true;

export function getStaticPaths() {
	const projects = getAllProjects();
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;

const metaDescription = `Maatwerk website voor ${project.title} - ${project.shortDescription} Bekijk dit ${project.industry.toLowerCase()} project uit ${project.location}.`;

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "Werk", url: "https://knapgemaakt.nl/werk/" },
	{ name: project.title, url: `https://knapgemaakt.nl/project/${project.slug}/` },
];

const pageTitle = `${project.title} | ${project.industry} | KNAP GEMAAKT.`;

const otherProjects = getAllProjects().filter((p) => p.slug !== project.slug).slice(0, 2);
---

<Layout title={pageTitle} description={metaDescription}>
	<BreadcrumbSchema items={breadcrumbs} />
	<main>
		<!-- Hero -->
		<section class="pt-28 md:pt-36 pb-12 md:pb-16 px-6 md:px-12 lg:px-16">
			<div class="max-w-5xl mx-auto">
				<!-- Breadcrumb -->
				<nav class="flex items-center gap-2 text-sm text-ink/40 mb-8">
					<a href="/" class="hover:text-ink transition-colors">Home</a>
					<span>/</span>
					<a href="/werk/" class="hover:text-ink transition-colors">Werk</a>
					<span>/</span>
					<span class="text-ink/70">{project.title}</span>
				</nav>

				<div class="flex flex-wrap items-center gap-3 mb-5">
					<span class="inline-block px-3 py-1 bg-accent text-white text-xs font-bold rounded-full uppercase tracking-wide">
						{project.category}
					</span>
					<span class="text-ink/50 text-sm">
						{project.industry} · {project.location}
					</span>
				</div>

				<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-5">
					{project.title}
				</h1>

				<p class="text-xl text-ink/70 max-w-2xl leading-relaxed mb-8">
					{project.shortDescription}
				</p>

				<div class="flex flex-col sm:flex-row gap-3">
					<a
						href={project.link}
						target="_blank"
						rel="noopener noreferrer"
						class="bg-ink text-canvas px-7 py-3.5 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
					>
						Bekijk live website
						<span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
					</a>
					<a
						href="/aanvragen/"
						class="border-2 border-ink/15 text-ink px-7 py-3 rounded-lg font-bold tracking-tight hover:border-ink hover:bg-ink hover:text-canvas transition-all duration-300 text-center"
					>
						Start jouw project
					</a>
				</div>
			</div>
		</section>

		<!-- Hero Image -->
		<section class="px-6 md:px-12 lg:px-16 pb-16 md:pb-24">
			<div class="max-w-5xl mx-auto">
				<div class="aspect-[16/9] rounded-2xl overflow-hidden bg-canvas-alt shadow-lg">
					<img
						src={project.heroMockup || project.image}
						alt={`${project.title} website`}
						width={1920}
						height={1080}
						loading="eager"
						fetchpriority="high"
						decoding="async"
						class="w-full h-full object-cover"
					/>
				</div>
			</div>
		</section>

		<!-- Context -->
		<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
			<div class="max-w-3xl mx-auto">
				<FadeIn>
					<h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
						Het verhaal
					</h2>
					<div class="text-lg text-ink/80 leading-relaxed whitespace-pre-line">
						{project.fullDescription}
					</div>
				</FadeIn>
			</div>
		</section>

		<!-- Challenge & Solution -->
		<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
			<div class="max-w-5xl mx-auto">
				<div class="grid md:grid-cols-2 gap-12 md:gap-16">
					<FadeIn>
						<div>
							<span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-3 block">Uitdaging</span>
							<h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-5">
								De vraag
							</h2>
							<p class="text-lg text-ink/80 leading-relaxed whitespace-pre-line">
								{project.challenge}
							</p>
						</div>
					</FadeIn>

					<FadeIn delay={100}>
						<div>
							<span class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-3 block">Oplossing</span>
							<h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-5">
								De aanpak
							</h2>
							<p class="text-lg text-ink/80 leading-relaxed whitespace-pre-line">
								{project.solution}
							</p>
						</div>
					</FadeIn>
				</div>
			</div>
		</section>

		<!-- Features & Technical -->
		<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
			<div class="max-w-5xl mx-auto">
				<div class="grid md:grid-cols-2 gap-12 md:gap-16">
					<FadeIn>
						<div>
							<h3 class="text-2xl md:text-3xl font-bold tracking-tight mb-8">
								Functionaliteit
							</h3>
							<ul class="space-y-4">
								{project.features.map((feature) => (
									<li class="flex items-start gap-3 text-lg text-ink/80">
										<span class="text-accent mt-1 font-bold">&#10003;</span>
										<span>{feature}</span>
									</li>
								))}
							</ul>
						</div>
					</FadeIn>

					{project.technicalHighlights && project.technicalHighlights.length > 0 && (
						<FadeIn delay={100}>
							<div>
								<h3 class="text-2xl md:text-3xl font-bold tracking-tight mb-8">
									Performance
								</h3>
								<ul class="space-y-4">
									{project.technicalHighlights.map((highlight) => (
										<li class="flex items-start gap-3 text-lg text-ink/80">
											<span class="text-accent mt-1 font-bold">&rarr;</span>
											<span>{highlight}</span>
										</li>
									))}
								</ul>
							</div>
						</FadeIn>
					)}
				</div>
			</div>
		</section>

		<!-- Results -->
		{project.results && project.results.length > 0 && (
			<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
				<div class="max-w-3xl mx-auto">
					<FadeIn>
						<h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">
							Resultaat
						</h2>
						<ul class="space-y-4">
							{project.results.map((result) => (
								<li class="flex items-start gap-4 text-lg text-ink/80">
									<span class="text-accent font-bold text-xl">&rarr;</span>
									<span class="leading-relaxed">{result}</span>
								</li>
							))}
						</ul>
					</FadeIn>
				</div>
			</section>
		)}

		<!-- Testimonial -->
		{project.testimonial && (
			<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-ink text-canvas">
				<div class="max-w-3xl mx-auto text-center">
					<FadeIn>
						<blockquote class="text-2xl md:text-3xl font-bold leading-snug mb-6">
							"{project.testimonial.quote}"
						</blockquote>
						<div class="text-accent font-bold text-sm">{project.testimonial.author}</div>
						<div class="text-canvas/50 text-sm mt-1">{project.testimonial.role}</div>
					</FadeIn>
				</div>
			</section>
		)}

		<!-- More Projects -->
		{otherProjects.length > 0 && (
			<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
				<div class="max-w-5xl mx-auto">
					<div class="flex items-center justify-between mb-10">
						<h2 class="text-3xl md:text-4xl font-bold tracking-tight">
							Meer werk
						</h2>
						<a
							href="/werk/"
							class="hidden md:inline-flex items-center gap-2 text-ink/50 hover:text-ink text-sm font-bold transition-colors group"
						>
							Alles bekijken
							<span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
						</a>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						{otherProjects.map((related) => (
							<a
								href={`/project/${related.slug}/`}
								class="group block rounded-2xl border border-warm bg-white overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
							>
								<div class="aspect-[16/10] overflow-hidden">
									<img
										src={related.overviewMockup || related.heroMockup || related.image}
										alt={`${related.title} website`}
										width="800"
										height="500"
										class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
										loading="lazy"
										decoding="async"
									/>
								</div>
								<div class="p-6">
									{related.category === "Live" ? (
										<span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-accent text-white px-2.5 py-1 rounded-full mb-3">LIVE</span>
									) : (
										<span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2.5 py-1 rounded-full mb-3">IN ONTWIKKELING</span>
									)}
									<h3 class="font-bold text-xl group-hover:text-accent transition-colors">{related.title}</h3>
									<p class="text-ink/60 text-sm mt-1">{related.industry} · {related.location}</p>
								</div>
							</a>
						))}
					</div>

					<a
						href="/werk/"
						class="md:hidden mt-8 inline-flex items-center gap-2 text-ink/50 hover:text-ink text-sm font-bold transition-colors group"
					>
						Alles bekijken
						<span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
					</a>
				</div>
			</section>
		)}
	</main>
	<Footer />
</Layout>
