---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import BlogPostSchema from "../../components/seo/BlogPostSchema.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import BlogCardImage from "../../components/blog/BlogCardImage.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

interface Props {
	post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();

// Get other posts for "Verder lezen" section (exclude current post, max 3)
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const otherPosts = allPosts
	.filter((p) => p.slug !== post.slug)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 3);

// Calculate reading time from content (rough estimate: 200 words/min)
const wordCount = post.body.split(/\s+/).length;
const readingTime = post.data.readingTime || Math.ceil(wordCount / 200);

// Format dates
const publishDate = post.data.publishDate.toLocaleDateString("nl-NL", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const updatedDate = post.data.updatedDate?.toLocaleDateString("nl-NL", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

// SEO
const metaTitle = post.data.metaTitle || `${post.data.title} | KNAP GEMAAKT.`;
const metaDescription = post.data.description;

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "Blog", url: "https://knapgemaakt.nl/blog/" },
	{ name: post.data.title, url: `https://knapgemaakt.nl/blog/${post.slug}/` },
];
---

<Layout title={metaTitle} description={metaDescription}>
	<BlogPostSchema
		title={post.data.title}
		description={post.data.description}
		publishDate={post.data.publishDate}
		updatedDate={post.data.updatedDate}
		author={post.data.author}
		slug={post.slug}
		tags={post.data.tags}
		readingTime={readingTime}
		image={post.data.image}
	/>
	<BreadcrumbSchema items={breadcrumbs} />

	<!-- Reading progress bar -->
	<div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-accent z-50 transition-none" style="width: 0%"></div>

	<main class="bg-canvas">
		<article class="pt-28 md:pt-32">
			<!-- Header -->
			<header class="px-6 md:px-12 lg:px-16 pb-8 md:pb-10">
				<div class="max-w-2xl mx-auto">
					<!-- Back + Tags row -->
					<div class="flex items-center justify-between mb-8">
						<a
							href="/blog/"
							class="inline-flex items-center gap-2 text-ink/40 hover:text-ink text-sm transition-colors"
						>
							<span>&larr;</span>
							<span>Blog</span>
						</a>
						{post.data.tags.length > 0 && (
							<div class="flex gap-2">
								{post.data.tags.map((tag) => (
									<a
										href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, "-")}/`}
										class="px-3 py-1 bg-ink/5 text-ink/60 text-xs font-medium rounded-full hover:bg-ink/10 hover:text-ink transition-colors"
									>
										{tag}
									</a>
								))}
							</div>
						)}
					</div>

					<!-- Title -->
					<h1 class="text-3xl md:text-4xl lg:text-[2.75rem] font-bold tracking-tight leading-tight mb-5">
						{post.data.title}
					</h1>

					<!-- Description -->
					<p class="text-lg md:text-xl text-ink/70 leading-relaxed mb-8">
						{post.data.description}
					</p>

					<!-- Byline -->
					<div class="flex items-center gap-3">
						<a href="/over/" class="flex-shrink-0">
							<img
								src="/assets/yannick.webp"
								alt="Yannick Veldhuisen"
								width="40"
								height="40"
								class="w-10 h-10 rounded-full object-cover object-top"
								loading="lazy"
								decoding="async"
							/>
						</a>
						<div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
							<a href="/over/" class="font-semibold text-ink hover:text-ink/70 transition-colors">
								{post.data.author}
							</a>
							<span class="text-ink/30">/</span>
							<time datetime={post.data.publishDate.toISOString()} class="text-ink/50">
								{publishDate}
							</time>
							<span class="text-ink/30">/</span>
							<span class="text-ink/50">{readingTime} min lezen</span>
							{updatedDate && (
								<>
									<span class="text-ink/30">/</span>
									<span class="text-ink/50">Bijgewerkt {updatedDate}</span>
								</>
							)}
						</div>
					</div>
				</div>
			</header>

			<!-- Featured Image -->
			<div class="px-6 md:px-12 lg:px-16 pb-8 md:pb-12">
				<div class="max-w-3xl mx-auto">
					<div class="aspect-[16/9] rounded-2xl overflow-hidden bg-ink shadow-lg">
						<img
							src={post.data.image}
							alt={post.data.imageAlt || post.data.title}
							class="w-full h-full object-cover"
							loading="eager"
							fetchpriority="high"
							decoding="async"
						/>
					</div>
				</div>
			</div>

			<!-- Content -->
			<div class="px-6 md:px-12 lg:px-16 pb-16 md:pb-24">
				<div class="max-w-2xl mx-auto">
					<div class="blog-content-light">
						<Content />
					</div>
				</div>
			</div>

			<!-- Author Bio -->
			<section class="px-6 md:px-12 lg:px-16 py-10 md:py-14 bg-canvas-alt border-y border-warm">
				<div class="max-w-2xl mx-auto flex items-center gap-5">
					<a href="/over/" class="flex-shrink-0">
						<img
							src="/assets/yannick.webp"
							alt="Yannick Veldhuisen"
							width="56"
							height="56"
							class="w-14 h-14 rounded-full object-cover object-top hover:opacity-80 transition-opacity"
							loading="lazy"
							decoding="async"
						/>
					</a>
					<div>
						<a href="/over/" class="font-bold text-base block hover:text-ink/70 transition-colors mb-1">
							{post.data.author}
						</a>
						<p class="text-ink/60 text-sm leading-relaxed">
							Websites die niet alleen mooi zijn, maar ook echt meewerken. Gevestigd in Buren, werkend door heel Nederland.
						</p>
					</div>
				</div>
			</section>

			<!-- Verder lezen -->
			{otherPosts.length > 0 && (
				<section class="px-6 md:px-12 lg:px-16 py-14 md:py-20">
					<div class="max-w-4xl mx-auto">
						<h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-10">Verder lezen</h2>
						<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
							{otherPosts.map((otherPost) => (
								<BlogCardImage
									title={otherPost.data.title}
									description={otherPost.data.description}
									publishDate={otherPost.data.publishDate}
									slug={otherPost.slug}
									image={otherPost.data.image}
									imageAlt={otherPost.data.imageAlt}
									tags={otherPost.data.tags}
									readingTime={otherPost.data.readingTime}
								/>
							))}
						</div>
					</div>
				</section>
			)}
		</article>

		<Footer />
	</main>
</Layout>

<script>
	function initReadingProgress() {
		const bar = document.getElementById("reading-progress");
		if (!bar) return;

		function updateProgress() {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
			bar.style.width = `${progress}%`;
		}

		window.addEventListener("scroll", updateProgress, { passive: true });
		updateProgress();
	}

	initReadingProgress();
	document.addEventListener("astro:page-load", initReadingProgress);
</script>
