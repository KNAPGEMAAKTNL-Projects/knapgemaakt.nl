---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import FadeIn from "../components/FadeIn.astro";
import FAQSection from "../components/FAQSection.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ServiceSchema from "../components/seo/ServiceSchema.astro";
import { getAllProjects } from "../data/projects";

const projects = getAllProjects();

const breadcrumbs = [
	{ name: "Home", url: "https://knapgemaakt.nl/" },
	{ name: "Webdesign", url: "https://knapgemaakt.nl/webdesign/" }
];
---

<Layout
  title="Webdesign | Websites op maat gebouwd | KNAP GEMAAKT."
  description="Websites vanaf de grond opgebouwd. Geen templates, geen trage plugins. Snel, overzichtelijk en precies passend bij jouw bedrijf. KNAP GEMAAKT. uit Buren."
>
  <ServiceSchema
    name="Webdesign op maat"
    description="Websites vanaf de grond opgebouwd met Astro. Snel, veilig en passend bij jouw bedrijf."
    serviceType="WebDesign"
    url="https://knapgemaakt.nl/webdesign/"
    price="595"
  />
  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <div class="mb-6">
          <Breadcrumb items={breadcrumbs} />
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-snug mb-6">
          Een website die past bij je bedrijf
        </h1>
        <p class="text-lg md:text-xl text-ink/70 max-w-2xl leading-relaxed mb-4">
          Vanaf de grond opgebouwd. Geen WordPress-template waar je logo op wordt geplakt, geen pagina vol plugins die alles traag maken, geen beheersysteem waar je een cursus voor nodig hebt.
        </p>
        <p class="text-lg md:text-xl text-ink/70 max-w-2xl leading-relaxed">
          Een snelle, overzichtelijke website die er goed uitziet op elk scherm. Gebouwd voor jouw bedrijf, niet voor duizend anderen.
        </p>
      </div>
    </section>

    <!-- What makes it different -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-6">
            Waarom geen template?
          </h2>
          <div class="grid md:grid-cols-2 gap-10 md:gap-16">
            <div>
              <p class="text-ink/70 leading-relaxed mb-6">
                De meeste websites voor kleine bedrijven draaien op WordPress met een kant-en-klaar thema. Dat werkt, maar het is traag. Tientallen plugins die bij elke pagina meeladen, updates die dingen stuk maken, en laadtijden waar je bezoekers niet op zitten te wachten.
              </p>
              <p class="text-ink/70 leading-relaxed">
                Ik bouw elke website op maat. Geen overbodige plugins, geen trage laadtijden, geen ingewikkeld beheersysteem. Wat je bedrijf nodig heeft, en niks meer.
              </p>
            </div>
            <div>
              <ul class="space-y-4">
                {[
                  "Elk ontwerp is uniek, gebouwd voor jouw bedrijf",
                  "Razendsnel, ook op een langzame verbinding",
                  "Werkt perfect op mobiel, tablet en desktop",
                  "Geen plugins die updates nodig hebben",
                  "Gebouwd om goed te scoren in Google",
                  "Teksten kan ik voor je schrijven",
                  "Hosting en domeinnaam erbij geregeld"
                ].map((feature) => (
                  <li class="flex items-start gap-3 text-ink/70">
                    <div class="w-2 h-2 rounded-full bg-accent shrink-0 mt-2.5"></div>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Projects showcase -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-10">
            Voorbeelden
          </h2>
          <div class="grid sm:grid-cols-2 gap-8">
            {projects.map(project => (
              <a
                href={`/project/${project.slug}/`}
                class="group block rounded-2xl overflow-hidden border border-warm hover:border-accent transition-colors duration-300"
              >
                <div class="aspect-[16/10] overflow-hidden bg-canvas-alt">
                  {project.overviewMockup ? (
                    <img
                      src={project.overviewMockup}
                      alt={project.title}
                      width="1200"
                      height="750"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="text-ink/40 text-sm flex items-center justify-center h-full">Preview</span>
                  )}
                </div>
                <div class="p-5 bg-canvas">
                  {project.category === "Live" ? (
                    <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-accent text-white px-2 py-0.5 rounded-full mb-2">LIVE</span>
                  ) : (
                    <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2 py-0.5 rounded-full mb-2">IN ONTWIKKELING</span>
                  )}
                  <h3 class="font-bold text-lg mb-1 group-hover:text-accent transition-colors duration-300">{project.title}</h3>
                  <p class="text-ink/70 text-sm">{project.industry} · {project.location}</p>
                </div>
              </a>
            ))}

            <!-- Demo Hovenier -->
            <a
              href="https://demo-hovenier.knapgemaakt.nl"
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-2xl overflow-hidden border border-warm hover:border-accent transition-colors duration-300"
            >
              <div class="aspect-[16/10] overflow-hidden bg-canvas-alt">
                <img
                  src="/assets/projects/demo-hovenier.webp"
                  alt="Demo website voor hoveniersbedrijf"
                  width="2304"
                  height="1536"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5 bg-canvas">
                <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2 py-0.5 rounded-full mb-2">DEMO</span>
                <h3 class="font-bold text-lg mb-1 group-hover:text-accent transition-colors duration-300">Hovenier Demo</h3>
                <p class="text-ink/70 text-sm">Demo website voor hoveniers</p>
              </div>
            </a>

            <!-- Demo Elektricien -->
            <a
              href="https://demo-elektricien.knapgemaakt.nl"
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-2xl overflow-hidden border border-warm hover:border-accent transition-colors duration-300"
            >
              <div class="aspect-[16/10] overflow-hidden bg-canvas-alt">
                <img
                  src="/assets/projects/demo-elektricien.webp"
                  alt="Demo website voor elektricien"
                  width="2304"
                  height="1536"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5 bg-canvas">
                <span class="inline-block text-[10px] font-bold uppercase tracking-widest bg-ink/10 text-ink px-2 py-0.5 rounded-full mb-2">DEMO</span>
                <h3 class="font-bold text-lg mb-1 group-hover:text-accent transition-colors duration-300">Elektricien Demo</h3>
                <p class="text-ink/70 text-sm">Demo website voor elektriciens</p>
              </div>
            </a>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Process -->
    <section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-6">
            Mijn werkwijze
          </h2>
          <div class="grid md:grid-cols-3 gap-8 md:gap-12">
            <div>
              <div class="w-10 h-10 rounded-full bg-ink text-canvas flex items-center justify-center font-bold text-sm mb-4">1</div>
              <h3 class="font-bold text-lg mb-2">Kennismaken</h3>
              <p class="text-ink/70 leading-relaxed">
                We beginnen met een gesprek over je bedrijf, je klanten en wat je wilt uitstralen. Op basis daarvan maak ik een voorstel met een duidelijk plan en prijs.
              </p>
            </div>
            <div>
              <div class="w-10 h-10 rounded-full bg-ink text-canvas flex items-center justify-center font-bold text-sm mb-4">2</div>
              <h3 class="font-bold text-lg mb-2">Ontwerp en bouw</h3>
              <p class="text-ink/70 leading-relaxed">
                Ik ga aan de slag met het ontwerp en de teksten. Tussendoor laat ik je zien hoe het ervoor staat en verwerk ik je feedback. Zo groeit de website samen met jouw idee.
              </p>
            </div>
            <div>
              <div class="w-10 h-10 rounded-full bg-ink text-canvas flex items-center justify-center font-bold text-sm mb-4">3</div>
              <h3 class="font-bold text-lg mb-2">Online</h3>
              <p class="text-ink/70 leading-relaxed">
                Als alles goed staat, gaat de website live. Hosting, domeinnaam en eventueel e-mail regel ik erbij. Vanaf dat moment is je bedrijf professioneel online.
              </p>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- Na oplevering: Pakketten -->
    <section class="py-16 md:py-20 px-6 md:px-12 lg:px-16 bg-canvas-alt">
      <div class="max-w-5xl mx-auto">
        <FadeIn>
          <div class="grid md:grid-cols-[3fr_2fr] gap-10 md:gap-16 items-center">
            <div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">
                Na oplevering draait alles door
              </h2>
              <p class="text-ink/70 leading-relaxed mb-4">
                Een website is nooit helemaal klaar. Er komen nieuwe diensten, andere openingstijden, nieuwe foto's. Dat regel ik voor je, binnen een vast maandbedrag.
              </p>
              <p class="text-ink/70 leading-relaxed mb-6">
                Drie pakketten om uit te kiezen. Essentieel voor wie het rustig aan doet. Groei voor wie actief wil groeien via Google. Compleet voor wie alles uit handen wil geven.
              </p>
              <a
                href="/pakketten/"
                class="inline-flex items-center gap-2 text-ink font-bold hover:text-accent transition-colors group"
              >
                Bekijk de pakketten
                <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
              </a>
            </div>
            <div class="bg-canvas rounded-xl p-6 border border-warm">
              <div class="space-y-4 text-sm">
                <div class="flex items-baseline justify-between pb-3 border-b border-warm">
                  <span class="font-bold">Essentieel</span>
                  <span class="font-mono text-ink/60">&euro;49 / mo</span>
                </div>
                <div class="flex items-baseline justify-between pb-3 border-b border-warm">
                  <span class="font-bold">Groei</span>
                  <span class="font-mono text-ink/60">&euro;99 / mo</span>
                </div>
                <div class="flex items-baseline justify-between">
                  <span class="font-bold">Compleet</span>
                  <span class="font-mono text-ink/60">&euro;149 / mo</span>
                </div>
              </div>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>

    <!-- FAQ -->
    <FadeIn>
    <FAQSection faqs={[
    	{
    		question: "Wat kost een website laten maken?",
    		answer: "Je betaalt een vast maandbedrag. Essentieel vanaf EUR 49 per maand, met ontwerp, bouw, hosting en onderhoud erin. Voor bedrijven die meer willen zijn er twee hogere pakketten. Kijk op de pakketten-pagina voor het volledige overzicht."
    	},
    	{
    		question: "Hoe lang duurt het om een website te bouwen?",
    		answer: "Een eenvoudige bedrijfssite kan binnen een paar dagen klaar zijn. Grotere projecten met extra functionaliteit duren een paar weken. Projecten met automatisering of koppelingen kunnen iets langer duren."
    	},
    	{
    		question: "Waarom geen WordPress?",
    		answer: "WordPress is prima voor blogs, maar voor een snelle bedrijfssite zijn er betere opties. Ik bouw met Astro: dat laadt sneller, heeft geen plugins nodig en is veiliger. Het resultaat scoort beter in Google en kost minder onderhoud."
    	},
    	{
    		question: "Kan ik zelf teksten aanpassen?",
    		answer: "Kleine aanpassingen regel ik voor je, meestal binnen 24 uur. Grotere wijzigingen plannen we samen in. Je hoeft zelf niets technisch te doen."
    	},
    	{
    		question: "Wat heb je van mij nodig om te beginnen?",
    		answer: "Eigenlijk vooral een goed gesprek. Ik wil begrijpen wat je bedrijf doet en wie je klanten zijn. Verder zijn logo, foto's en een idee van welke pagina's je wilt handig, maar niet verplicht om te starten."
    	}
    ]} />
    </FadeIn>

    <!-- CTA -->
    <section class="py-20 md:py-28 px-6 md:px-12 lg:px-16">
      <div class="max-w-3xl mx-auto text-center">
        <FadeIn>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-6">
            Website op je to-do lijst?
          </h2>
          <p class="text-ink/70 text-lg leading-relaxed mb-8">
            Vertel me over je bedrijf. Ik denk mee over wat je nodig hebt en kom met een voorstel.
          </p>
          <a
            href="/aanvragen/?onderwerp=webdesign"
            class="bg-ink text-canvas px-8 py-4 rounded-lg font-bold tracking-tight hover:bg-ink/80 transition-colors duration-300 inline-flex items-center justify-center gap-3 group"
          >
            Plan een gesprek in
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </FadeIn>
      </div>
    </section>
  </main>
  <Footer hideCTA={true} />
</Layout>
