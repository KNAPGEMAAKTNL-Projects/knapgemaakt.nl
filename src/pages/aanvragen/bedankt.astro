---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
---

<Layout
	title="Aanvraag Ontvangen | KNAP GEMAAKT."
	description="Bedankt voor je aanvraag! Je gesprek is ingepland en je ontvangt een bevestiging per e-mail. We spreken je snel!"
>
    <main class="min-h-screen bg-canvas pt-32 pb-24 px-4 md:px-8 relative overflow-hidden">
        <div class="max-w-4xl mx-auto">
            <div class="text-center py-16 space-y-6">
                <div
                    class="w-20 h-20 mx-auto bg-accent flex items-center justify-center rounded-xl"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-10 w-10 text-canvas"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="square"
                            stroke-linejoin="miter"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
                <h1
                    class="text-4xl md:text-6xl font-bold tracking-tight leading-snug"
                >
                    Aanvraag Ontvangen
                </h1>
                <p class="text-xl text-ink-secondary max-w-lg mx-auto">
                    Bedankt voor je aanvraag! Je gesprek is ingepland.
                    Check je inbox voor de bevestiging.
                </p>
                <a
                    href="/"
                    class="inline-flex items-center justify-center mt-8 px-8 py-4 bg-ink text-canvas rounded-lg hover:bg-ink/80 transition-colors duration-300 font-bold tracking-tight"
                >
                    Terug naar home
                </a>
            </div>
        </div>
    </main>
    <Footer hideCTA />
</Layout>
