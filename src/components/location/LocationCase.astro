---
import FadeIn from "../FadeIn.astro";
import { getProjectBySlug } from "../../data/projects";

interface Props {
	caseSlug?: string;
	regionCommonTraits: string;
	cityName: string;
}

const { caseSlug, regionCommonTraits } = Astro.props;
const project = caseSlug ? getProjectBySlug(caseSlug) : null;
const projectParagraphs = project?.fullDescription.split(/\n\n+/) ?? [];
const mockup = project?.overviewMockup ?? project?.heroMockup ?? project?.image;
---

<section class="py-16 md:py-24 px-6 md:px-12 lg:px-16 bg-canvas">
	<div class="max-w-5xl mx-auto">
		{project ? (
			<FadeIn>
				<span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60 mb-4 block">Eerder werk in de regio</span>
				<h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-8">
					{project.title}
				</h2>

				{mockup && (
					<div class="aspect-[16/10] bg-gradient-to-br from-canvas-alt to-canvas rounded-2xl overflow-hidden border border-warm mb-8">
						<img
							src={mockup}
							alt={`Website van ${project.title}`}
							width="1200"
							height="750"
							loading="lazy"
							decoding="async"
							class="w-full h-full object-cover"
						/>
					</div>
				)}

				<div class="max-w-3xl space-y-4 mb-8">
					{projectParagraphs.map((para) => (
						<p class="text-lg text-ink-secondary leading-relaxed">{para}</p>
					))}
				</div>

				<a
					href={`/project/${project.slug}/`}
					class="inline-flex items-center gap-3 text-ink font-bold tracking-tight hover:text-accent transition-colors group"
				>
					Bekijk de volledige case
					<span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
				</a>
			</FadeIn>
		) : (
			<div class="max-w-3xl">
				<FadeIn>
					<span class="text-xs font-bold uppercase tracking-widest text-ink-secondary/60 mb-4 block">Voor wie ik werk in deze regio</span>
					<p class="text-lg text-ink-secondary leading-relaxed">
						{regionCommonTraits}
					</p>
				</FadeIn>
			</div>
		)}
	</div>
</section>
