---
/**
 * Trust-strip with recognizable brand logos that KNAP GEMAAKT. actually integrates
 * with. Shown just below the hero on the homepage and at the bottom of
 * /automatisering/. Logos are rendered at ~60% opacity so mixed brand colors
 * read as a uniform row; hover returns them to full opacity.
 *
 * Legal: every logo below is displayed under nominative fair use or explicit
 * brand-kit permission. The disclaimer line at the bottom is the
 * standard Dutch boilerplate for descriptive use.
 */

interface Props {
  heading?: string;
  variant?: "light" | "dark";
}

const { heading = "Werkt samen met", variant = "light" } = Astro.props;

const logos = [
  {
    src: "/assets/logos/google-reviews.png",
    alt: "Google Reviews",
    width: 120,
    height: 40,
  },
  {
    src: "/assets/logos/mollie.png",
    alt: "Mollie",
    width: 100,
    height: 32,
  },
  {
    src: "/assets/logos/ideal-wero.png",
    alt: "iDEAL | Wero",
    width: 130,
    height: 40,
  },
  {
    src: "/assets/logos/whatsapp.svg",
    alt: "WhatsApp",
    width: 40,
    height: 40,
  },
  {
    src: "/assets/logos/cloudflare.png",
    alt: "Cloudflare",
    width: 110,
    height: 32,
  },
];

const isDark = variant === "dark";
---

<section
  class:list={[
    "py-10 md:py-14 px-6 md:px-12 lg:px-16",
    isDark ? "bg-ink text-canvas" : "bg-canvas border-t border-b border-warm",
  ]}
>
  <div class="max-w-5xl mx-auto">
    <p
      class:list={[
        "text-xs font-mono uppercase tracking-widest text-center mb-6 md:mb-8",
        isDark ? "text-canvas/40" : "text-ink/40",
      ]}
    >
      {heading}
    </p>
    <ul class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:gap-x-14">
      {logos.map((logo) => (
        <li>
          <img
            src={logo.src}
            alt={logo.alt}
            width={logo.width}
            height={logo.height}
            loading="lazy"
            decoding="async"
            class:list={[
              "h-8 md:h-10 w-auto transition-opacity duration-200",
              isDark ? "opacity-50 hover:opacity-90" : "opacity-60 hover:opacity-100",
            ]}
          />
        </li>
      ))}
    </ul>
    <p
      class:list={[
        "text-[10px] text-center mt-6 md:mt-8 max-w-3xl mx-auto leading-relaxed",
        isDark ? "text-canvas/30" : "text-ink/30",
      ]}
    >
      Genoemde merknamen en logo's zijn eigendom van hun respectieve eigenaren. KNAP GEMAAKT. integreert met deze diensten voor klanten en is geen officiële partner tenzij expliciet vermeld.
    </p>
  </div>
</section>
