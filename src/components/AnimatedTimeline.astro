---
interface Step {
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<div class="process-timeline">
  <!-- ===== DESKTOP: Horizontal stepper with connecting line ===== -->
  <div class="hidden md:block relative">
    <!-- Background track line (runs through the center of the dots) -->
    <div class="absolute top-[28px] left-[12.5%] right-[12.5%] h-[2px] bg-warm/50" aria-hidden="true"></div>
    <!-- Animated progress line -->
    <div class="absolute top-[28px] left-[12.5%] right-[12.5%] h-[2px] overflow-hidden" aria-hidden="true">
      <div class="process-line h-full bg-accent origin-left transition-transform duration-500 ease-out" style="transform: scaleX(0)"></div>
    </div>

    <div class="grid grid-cols-4 gap-6 lg:gap-10">
      {steps.map((step, i) => (
        <div class="process-step group" data-step={i}>
          <!-- Numbered circle -->
          <div class="process-dot relative z-10 w-14 h-14 mx-auto rounded-full border-2 border-warm bg-canvas flex items-center justify-center mb-8 transition-all duration-500">
            <span class="process-dot-num text-lg font-bold text-ink-secondary/30 transition-colors duration-500">
              {i + 1}
            </span>
          </div>
          <!-- Card -->
          <div class="process-card glass-card p-6 text-center transition-all duration-500 opacity-60">
            <h3 class="text-lg font-bold tracking-tight mb-2">{step.title}</h3>
            <p class="text-ink-secondary text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== MOBILE: Vertical cards with large numbers ===== -->
  <div class="md:hidden relative">
    <!-- Vertical track line -->
    <div class="absolute left-[23px] top-0 bottom-0 w-[2px] bg-warm/50" aria-hidden="true"></div>
    <!-- Animated vertical progress line -->
    <div class="absolute left-[23px] top-0 bottom-0 w-[2px] overflow-hidden" aria-hidden="true">
      <div class="process-line-mobile h-full bg-accent origin-top transition-transform duration-500 ease-out" style="transform: scaleY(0)"></div>
    </div>

    <div class="space-y-8">
      {steps.map((step, i) => (
        <div class="process-step-mobile relative pl-16" data-step={i}>
          <!-- Numbered circle -->
          <div class="process-dot-mobile absolute left-0 top-0 z-10 w-12 h-12 rounded-full border-2 border-warm bg-canvas flex items-center justify-center transition-all duration-500">
            <span class="process-dot-num-mobile text-base font-bold text-ink-secondary/30 transition-colors duration-500">
              {i + 1}
            </span>
          </div>
          <!-- Content card -->
          <div class="process-card-mobile glass-card p-5 transition-all duration-500 opacity-60">
            <h3 class="text-lg font-bold tracking-tight mb-1">{step.title}</h3>
            <p class="text-ink-secondary text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  function initProcessTimeline() {
    const timeline = document.querySelector(".process-timeline");
    if (!timeline) return;

    // Desktop: horizontal line + step activation
    const progressLine = timeline.querySelector(".process-line") as HTMLElement;
    const desktopSteps = timeline.querySelectorAll(".process-step");

    // Mobile: vertical line + step activation
    const progressLineMobile = timeline.querySelector(".process-line-mobile") as HTMLElement;
    const mobileSteps = timeline.querySelectorAll(".process-step-mobile");

    // Activate a desktop step
    function activateDesktopStep(step: Element) {
      const dot = step.querySelector(".process-dot");
      const dotNum = step.querySelector(".process-dot-num");
      const card = step.querySelector(".process-card");
      if (dot) {
        dot.classList.add("border-accent", "bg-accent", "shadow-lg", "shadow-accent/20");
        dot.classList.remove("border-warm", "bg-canvas");
      }
      if (dotNum) {
        dotNum.classList.add("text-canvas");
        dotNum.classList.remove("text-ink-secondary/30");
      }
      if (card) {
        card.classList.remove("opacity-60");
        card.classList.add("opacity-100");
      }
    }

    // Activate a mobile step
    function activateMobileStep(step: Element) {
      const dot = step.querySelector(".process-dot-mobile");
      const dotNum = step.querySelector(".process-dot-num-mobile");
      const card = step.querySelector(".process-card-mobile");
      if (dot) {
        dot.classList.add("border-accent", "bg-accent", "shadow-lg", "shadow-accent/20");
        dot.classList.remove("border-warm", "bg-canvas");
      }
      if (dotNum) {
        dotNum.classList.add("text-canvas");
        dotNum.classList.remove("text-ink-secondary/30");
      }
      if (card) {
        card.classList.remove("opacity-60");
        card.classList.add("opacity-100");
      }
    }

    // Desktop step observer
    const desktopObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            activateDesktopStep(entry.target);
            desktopObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.6 }
    );
    desktopSteps.forEach((step) => desktopObserver.observe(step));

    // Mobile step observer
    const mobileObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            activateMobileStep(entry.target);
            mobileObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    mobileSteps.forEach((step) => mobileObserver.observe(step));

    // Scroll-driven progress line (desktop horizontal, mobile vertical)
    function updateProgress() {
      if (!timeline) return;
      const rect = timeline.getBoundingClientRect();
      const viewH = window.innerHeight;
      // Start filling when section enters viewport, complete when bottom exits
      const progress = Math.min(Math.max((viewH - rect.top) / (rect.height + viewH * 0.3), 0), 1);

      if (progressLine) {
        progressLine.style.transform = `scaleX(${progress})`;
      }
      if (progressLineMobile) {
        progressLineMobile.style.transform = `scaleY(${progress})`;
      }
    }

    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
  }

  initProcessTimeline();
  document.addEventListener("astro:after-swap", initProcessTimeline);
</script>
